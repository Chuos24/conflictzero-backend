# Conflict Zero - Variables de Entorno
# Copiar este archivo a .env y completar los valores

# ============================================
# APP
# ============================================
PROJECT_NAME=Conflict Zero API
ENVIRONMENT=development
DEBUG=true

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Local development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/conflict_zero

# Render (ejemplo)
# DATABASE_URL=postgresql://user:password@host.render.com:5432/conflict_zero

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# SECURITY
# ============================================
# Generar con: openssl rand -hex 32
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# Clave de 32 caracteres para encriptación de datos sensibles
ENCRYPTION_KEY=dev-encryption-key-32chars-long!!

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# API
# ============================================
API_V1_STR=/api/v1
RATE_LIMIT_PER_MINUTE=60

# ============================================
# EMAIL (SendGrid)
# ============================================
SENDGRID_API_KEY=
EMAIL_FROM=noreply@conflictzero.com

# ============================================
# WEBHOOKS
# ============================================
# Clave secreta para verificar webhooks de Culqi
CULQI_WEBHOOK_SECRET=

# ============================================
# EXTERNAL APIs
# ============================================
SUNAT_API_URL=
SUNAT_API_KEY=
OSCE_API_URL=
OSCE_API_KEY=
TCE_API_URL=
TCE_API_KEY=
FACTALIZA_API_KEY=

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO

# ============================================
# SENTRY (error tracking - opcional)
# ============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
