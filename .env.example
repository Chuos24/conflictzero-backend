# Conflict Zero - Variables de Entorno
# Copiar este archivo a .env y completar los valores

# ============================================
# APP
# ============================================
APP_NAME=Conflict Zero API
APP_VERSION=2.0.0
ENV=development
DEBUG=true

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Local development
DATABASE_URL=postgresql://cz_user:cz_password@localhost:5432/conflict_zero

# Render (ejemplo)
# DATABASE_URL=postgresql://user:password@host.render.com:5432/conflict_zero

# ============================================
# SECURITY
# ============================================
# Generar con: openssl rand -hex 32
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# Token para endpoints de admin
ADMIN_TOKEN=admin-dev-token-change-in-production

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# DIGITAL SIGNATURES (INDECOPI)
# ============================================
# demo = certificados con watermark
# production = certificados firmados legalmente
CERT_MODE=demo

# Ruta al certificado PKCS#12 de INDECOPI
INDECOPI_CERT_PATH=/app/certs/indecopi_cert.p12
INDECOPI_CERT_PASSWORD=

# ============================================
# EMAIL (SendGrid)
# ============================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@czperu.com
SENDGRID_FROM_NAME=Conflict Zero
EMAIL_ENABLED=false

# ============================================
# FRONTEND URLs
# ============================================
FRONTEND_URL=http://localhost:3000
FOUNDERS_URL=http://localhost:5500

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================
# FOUNDER PROGRAM
# ============================================
FOUNDER_MAX_SLOTS=10
FOUNDER_DURATION_MONTHS=3

# ============================================
# EXTERNAL APIs
# ============================================
# SUNAT API (si aplica)
SUNAT_API_URL=
SUNAT_API_KEY=

# OSCE API
OSCE_API_URL=
OSCE_API_KEY=

# TCE API
TCE_API_URL=
TCE_API_KEY=

# ============================================
# REDIS (opcional - para cache y rate limiting)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# SENTRY (error tracking - opcional)
# ============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
