# ============================
# ConflictZero - Variables de entorno
# Estas se configuran en AWS Lambda > Configuration > Environment variables
# NUNCA commitear el .env real
# ============================

# SUNAT / BuscarRUC
BUSCARUC_TOKEN=eyJxxx

# SendGrid (para notificaciones de certificados)
SENDGRID_API_KEY=SG.xxx

# AWS (auto-disponibles en Lambda, solo para desarrollo local)
AWS_REGION=us-east-1
S3_BUCKET=conflictzero-certificados-prod
DYNAMODB_TABLE=conflictzero-consultas

# CORS
ALLOWED_ORIGIN=https://czperu.com
